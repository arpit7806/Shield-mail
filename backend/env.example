# ============================================================
#  SHIELDMAIL — Environment Configuration
#  Copy to .env and fill in your values before running.
# ============================================================

PORT=3000
NODE_ENV=development
API_VERSION=v1

# Anthropic AI (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# n8n Automation Webhooks
N8N_WEBHOOK_DANGEROUS=https://your-n8n-instance.com/webhook/shieldmail-dangerous
N8N_WEBHOOK_SUSPICIOUS=https://your-n8n-instance.com/webhook/shieldmail-suspicious
N8N_WEBHOOK_REPORT=https://your-n8n-instance.com/webhook/shieldmail-report

# Alerts
ALERT_WHATSAPP_ENABLED=true
ALERT_SMS_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
